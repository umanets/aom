<Window x:Class="Aom.App.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AOM Overlay"
        AllowsTransparency="True"
        Background="Transparent"
        Focusable="False"
        ResizeMode="NoResize"
        ShowActivated="False"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        WindowStyle="None">
    <Grid IsHitTestVisible="False">
        <Border HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="28"
                Padding="18,16"
                MaxWidth="440"
                Background="#CC08111E"
                BorderBrush="#CC4FD1C5"
                BorderThickness="1"
                CornerRadius="18">
            <StackPanel>
                <TextBlock FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="#F3F7FA"
                           Text="AOM Overlay" />

                <TextBlock Margin="0,6,0,0"
                           Foreground="#97A8B8"
                           Text="{Binding OverlayBindingSummary}"
                           TextWrapping="Wrap" />

                <Border Margin="0,14,0,14"
                        BorderBrush="#334FD1C5"
                        BorderThickness="0,0,0,1" />

                <TextBlock Foreground="#4FD1C5"
                           Text="{Binding CurrentPresetDisplayName, StringFormat=Preset: {0}}" />

                <TextBlock Margin="0,6,0,0"
                           Foreground="#F3F7FA"
                           Text="{Binding Il2SpeedSummary}" />

                <TextBlock Margin="0,4,0,0"
                           Foreground="#97A8B8"
                           Text="{Binding Il2FlapsSummary}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>