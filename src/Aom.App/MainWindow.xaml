<Window x:Class="Aom.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="AOM Desktop"
        Width="1320"
        Height="820"
        MinWidth="1180"
        MinHeight="720"
        Background="#08111E"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#102033" />
        <SolidColorBrush x:Key="PanelBrushMuted" Color="#0C1828" />
        <SolidColorBrush x:Key="AccentBrush" Color="#4FD1C5" />
        <SolidColorBrush x:Key="AccentMutedBrush" Color="#173B45" />
        <SolidColorBrush x:Key="TextBrush" Color="#F3F7FA" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#97A8B8" />
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>
        <Style TargetType="Border">
            <Setter Property="CornerRadius" Value="18" />
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="26" Background="{StaticResource PanelBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="34" FontWeight="SemiBold" Text="{Binding AppTitle}" />
                    <TextBlock Margin="0,8,0,0"
                               FontSize="15"
                               Foreground="{StaticResource TextMutedBrush}"
                               Text="{Binding Subtitle}" />
                </StackPanel>

                <Border Grid.Column="1"
                        MinWidth="460"
                        Padding="18,14"
                        Background="{StaticResource AccentMutedBrush}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <DockPanel LastChildFill="True">
                            <TextBlock DockPanel.Dock="Left"
                                       Margin="0,0,8,0"
                                       FontSize="15"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Text="Output Target:" />
                            <TextBlock FontSize="15"
                                       FontWeight="SemiBold"
                                       Text="{Binding OutputTarget}"
                                       TextTrimming="CharacterEllipsis" />
                        </DockPanel>

                        <DockPanel Grid.Row="1"
                                   Margin="0,8,0,0"
                                   LastChildFill="True">
                            <TextBlock DockPanel.Dock="Left"
                                       Margin="0,0,8,0"
                                       FontSize="15"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Text="UDP Status:" />
                            <TextBlock Foreground="{StaticResource AccentBrush}"
                                       Text="{Binding UdpStreamingStatus}"
                                       TextTrimming="CharacterEllipsis" />
                        </DockPanel>

                        <TextBlock Grid.Row="2"
                                   Margin="0,8,0,0"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Text="{Binding UdpPacketSummary}"
                                   TextTrimming="CharacterEllipsis" />

                        <DockPanel Grid.Row="3"
                               Margin="0,10,0,0"
                               LastChildFill="True">
                            <TextBlock DockPanel.Dock="Left"
                                   Margin="0,0,8,0"
                                   FontSize="15"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Text="Overlay:" />
                            <TextBlock Foreground="{StaticResource AccentBrush}"
                                   Text="{Binding OverlayStatus}"
                                   TextTrimming="CharacterEllipsis" />
                        </DockPanel>

                        <TextBlock Grid.Row="4"
                               Margin="0,8,0,0"
                               Foreground="{StaticResource TextMutedBrush}"
                               Text="{Binding OverlayBindingSummary}"
                               TextTrimming="CharacterEllipsis" />

                        <TextBlock Grid.Row="5"
                               Margin="0,8,0,0"
                               Foreground="{StaticResource TextMutedBrush}"
                               Text="{Binding OverlaySupportSummary}"
                               TextWrapping="Wrap" />

                        <StackPanel Grid.Row="6"
                                Margin="0,12,0,0"
                                Orientation="Horizontal">
                            <Button Padding="12,7"
                                Command="{Binding ToggleUdpStreamingCommand}"
                                Content="{Binding UdpToggleLabel}" />
                            <Button Margin="10,0,0,0"
                                Padding="12,7"
                                Command="{Binding ToggleOverlayCommand}"
                                Content="{Binding OverlayToggleLabel}" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <TabControl Grid.Row="1"
                    Margin="0,18,0,0"
                    Background="Transparent"
                    BorderThickness="0"
                    SelectedIndex="{Binding SelectedMainTabIndex, Mode=TwoWay}">
            <TabItem Header="Control Map">
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.15*" />
                        <ColumnDefinition Width="5.85*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Margin="0,0,14,0"
                            Padding="18"
                            Background="{StaticResource PanelBrushMuted}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel>
                                <TextBlock FontSize="24" FontWeight="SemiBold" Text="Presets" />
                                <TextBlock Margin="0,6,0,0"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Text="Compact preset list with inline rename." />
                            </StackPanel>

                            <ListBox x:Name="PresetList"
                                     Grid.Row="1"
                                     Margin="0,18,0,0"
                                     Padding="0"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ItemsSource="{Binding Presets}"
                                     SelectedItem="{Binding SelectedPresetItem, Mode=TwoWay}">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Margin" Value="0,0,0,8" />
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="10,9">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{StaticResource PanelBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource AccentMutedBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock VerticalAlignment="Center"
                                                           FontSize="16"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding DisplayName}"
                                                           TextTrimming="CharacterEllipsis">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <TextBox Grid.Column="0"
                                                         VerticalAlignment="Center"
                                                         Padding="8,4"
                                                         Background="#0A1524"
                                                         BorderBrush="#24415F"
                                                         BorderThickness="1"
                                                         Foreground="{StaticResource TextBrush}"
                                                         Text="{Binding EditableDisplayName, UpdateSourceTrigger=PropertyChanged}">
                                                    <TextBox.Style>
                                                        <Style TargetType="TextBox">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBox.Style>
                                                </TextBox>

                                                <Button Grid.Column="1"
                                                        Margin="10,0,0,0"
                                                        Padding="8,4"
                                                        Command="{Binding BeginRenameCommand}"
                                                        FontFamily="Segoe MDL2 Assets"
                                                        Content="&#xE70F;">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>

                                                <Button Grid.Column="2"
                                                        Margin="8,0,0,0"
                                                        Padding="8,4"
                                                        Command="{Binding DeleteCommand}"
                                                        FontFamily="Segoe MDL2 Assets"
                                                        Content="&#xE74D;">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding CanDelete}" Value="False">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>

                                                <Button Grid.Column="3"
                                                        Margin="10,0,0,0"
                                                        Padding="8,4"
                                                        Command="{Binding CommitRenameCommand}"
                                                        FontFamily="Segoe MDL2 Assets"
                                                        Content="&#xE73E;">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>

                                                <Button Grid.Column="4"
                                                        Margin="8,0,0,0"
                                                        Padding="8,4"
                                                        Command="{Binding CancelRenameCommand}"
                                                        FontFamily="Segoe MDL2 Assets"
                                                        Content="&#xE711;">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1"
                            Padding="20"
                            Background="{StaticResource PanelBrush}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel>
                                <TextBlock FontSize="24" FontWeight="SemiBold" Text="Control Map" />
                                <TextBlock Margin="0,6,0,0"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Text="Core bindings grouped by function and formatted like a working table." />
                            </StackPanel>

                            <Border Grid.Row="1"
                                    Margin="0,16,0,0"
                                    Padding="14,12"
                                    Background="#16263A">
                                <DockPanel LastChildFill="True">
                                    <Button DockPanel.Dock="Right"
                                            Margin="12,0,0,0"
                                            Padding="12,6"
                                            Command="{Binding CancelLearnModeCommand}"
                                            Content="Cancel" />
                                    <StackPanel>
                                        <TextBlock FontSize="17"
                                                   FontWeight="SemiBold"
                                                   Text="Learn Mode" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   Text="{Binding LearnModeStatus}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </DockPanel>
                            </Border>

                            <ScrollViewer Grid.Row="2"
                                          Margin="0,16,0,0"
                                          VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <ItemsControl ItemsSource="{Binding BindingGroups}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,14"
                                                        Padding="14"
                                                        Background="{StaticResource PanelBrushMuted}">
                                                    <StackPanel>
                                                        <TextBlock FontSize="18"
                                                                   FontWeight="SemiBold"
                                                                   Text="{Binding Title}" />
                                                        <TextBlock Margin="0,8,0,0"
                                                                   TextWrapping="Wrap"
                                                                   Foreground="{StaticResource TextMutedBrush}"
                                                                   Text="{Binding Description}" />
                                                        <Grid Margin="0,12,0,0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="2.5*" />
                                                                <ColumnDefinition Width="82" />
                                                                <ColumnDefinition Width="2.6*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock FontSize="11"
                                                                       Foreground="{StaticResource TextMutedBrush}"
                                                                       Text="ACTION" />
                                                            <TextBlock Grid.Column="1"
                                                                       FontSize="11"
                                                                       Foreground="{StaticResource TextMutedBrush}"
                                                                       Text="MODE" />
                                                            <TextBlock Grid.Column="2"
                                                                       FontSize="11"
                                                                       Foreground="{StaticResource TextMutedBrush}"
                                                                       Text="BINDING" />
                                                        </Grid>
                                                        <ItemsControl Margin="0,6,0,0"
                                                                      ItemsSource="{Binding Bindings}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Margin="0,0,0,4"
                                                                            Padding="10,9"
                                                                            Background="#0F1B2B"
                                                                            BorderBrush="#213A54"
                                                                            BorderThickness="1">
                                                                        <Grid>
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="2.5*" />
                                                                                <ColumnDefinition Width="82" />
                                                                                <ColumnDefinition Width="2.6*" />
                                                                                <ColumnDefinition Width="Auto" />
                                                                                <ColumnDefinition Width="Auto" />
                                                                            </Grid.ColumnDefinitions>
                                                                            <TextBlock VerticalAlignment="Center"
                                                                                       FontWeight="SemiBold"
                                                                                       Foreground="{StaticResource TextBrush}"
                                                                                       Text="{Binding Name}"
                                                                                       TextTrimming="CharacterEllipsis" />
                                                                            <Border Grid.Column="1"
                                                                                    VerticalAlignment="Center"
                                                                                    HorizontalAlignment="Left"
                                                                                    Padding="8,3"
                                                                                    Background="#12263A"
                                                                                    BorderBrush="#27445F"
                                                                                    BorderThickness="1">
                                                                                <TextBlock FontSize="11"
                                                                                           Foreground="{StaticResource TextMutedBrush}"
                                                                                           Text="{Binding ActivationModeLabel}" />
                                                                            </Border>
                                                                            <Border Grid.Column="2"
                                                                                    Margin="10,0,0,0"
                                                                                    Padding="10,5"
                                                                                    Background="#123841"
                                                                                    BorderBrush="#2B5A64"
                                                                                    BorderThickness="1">
                                                                                <TextBlock Foreground="{StaticResource AccentBrush}"
                                                                                           Text="{Binding Trigger}"
                                                                                           TextTrimming="CharacterEllipsis" />
                                                                            </Border>
                                                                            <Button Grid.Column="3"
                                                                                    Margin="10,0,0,0"
                                                                                    Padding="10,4"
                                                                                    MinWidth="92"
                                                                                    Background="#20354D"
                                                                                    BorderBrush="#33516F"
                                                                                    Foreground="{StaticResource TextBrush}"
                                                                                    Command="{Binding DataContext.BeginLearnModeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                    CommandParameter="{Binding}"
                                                                                    Content="{Binding LearnActionLabel}" />
                                                                        </Grid>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>

                            <Grid Grid.Row="3"
                                  Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Margin="0,0,12,0"
                                        Padding="14"
                                        Background="#16263A">
                                    <StackPanel>
                                        <TextBlock FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Text="Runtime" />
                                        <TextBlock Margin="0,8,0,0"
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   Text="{Binding RuntimeStateSummary}" />
                                        <TextBlock Margin="0,10,0,0"
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   Text="{Binding OutputPoseSummary}" />
                                        <TextBlock Margin="0,10,0,0"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   Text="{Binding UdpPacketCount, StringFormat=Packets {0}}" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   Text="{Binding UdpRateSummary}" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1"
                                        Margin="0,0,12,0"
                                        Padding="14"
                                        Background="#16263A">
                                    <StackPanel>
                                        <TextBlock FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Text="TrackIR" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   Text="{Binding TrackIrProbe.Status}" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   Text="{Binding LiveTrackIrStatus}" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   Text="{Binding TrackIrInputProfileSummary}" />
                                        <TextBlock Margin="0,10,0,0"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               Text="{Binding TrackIrYawMultiplierSummary}" />
                                        <Slider Margin="0,6,0,0"
                                            Minimum="0.25"
                                            Maximum="4.0"
                                            SmallChange="0.05"
                                            LargeChange="0.25"
                                            TickFrequency="0.25"
                                            Value="{Binding TrackIrYawMultiplier, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Margin="0,4,0,0"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               Text="Higher multiplier means less real head movement produces more in-game yaw. 1.00x keeps the current profile behavior." />
                                        <TextBlock Margin="0,6,0,0"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   Text="{Binding TrackIrRateSummary}" />
                                        <TextBlock Margin="0,6,0,0"
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   Text="{Binding LiveTrackIrPoseSummary}" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   Text="{Binding LiveTrackIrTimestamp}" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2"
                                        Padding="14"
                                        Background="#16263A">
                                    <StackPanel>
                                        <TextBlock FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Text="Input" />
                                        <TextBlock Margin="0,8,0,0"
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   Text="{Binding JoystickSummary.Summary}" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   Text="{Binding LiveJoystickSummary}" />
                                        <ItemsControl Margin="0,8,0,0"
                                                      ItemsSource="{Binding LiveJoystickStates}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Margin="0,0,0,6"
                                                               TextWrapping="Wrap"
                                                               Foreground="{StaticResource TextMutedBrush}"
                                                               Text="{Binding Summary}" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="AI Partner">
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.5*" />
                        <ColumnDefinition Width="4.5*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Margin="0,0,14,0"
                            Padding="18"
                            Background="{StaticResource PanelBrushMuted}">
                        <StackPanel>
                            <TextBlock FontSize="24" FontWeight="SemiBold" Text="AI Partner" />
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Text="MVP shell for briefing, API configuration, and live telemetry context." />

                            <CheckBox Margin="0,18,0,0"
                                      IsChecked="{Binding IsAiPartnerEnabled, Mode=TwoWay}">
                                <TextBlock Text="Enable AI Partner" />
                            </CheckBox>

                            <TextBlock Margin="0,18,0,0"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Text="OpenAI API" />
                            <TextBlock Margin="0,6,0,0"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Text="{Binding AiPartnerApiStatus}" />

                            <TextBlock Margin="0,18,0,0"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Text="Push-to-talk" />
                            <Border Margin="0,8,0,0"
                                    Padding="12"
                                    Background="#16263A"
                                    DataContext="{Binding AiPartnerPushToTalkBinding}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Text="Assignable button/key" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   Text="{Binding Trigger}" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding DataContext.AiPartnerPushToTalkStatus, RelativeSource={RelativeSource AncestorType=Window}}" />
                                    </StackPanel>

                                    <Button Grid.Column="1"
                                            Margin="12,0,0,0"
                                            Padding="12,6"
                                            Command="{Binding DataContext.BeginLearnModeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Content="{Binding LearnActionLabel}" />

                                    <Button Grid.Column="2"
                                            Margin="8,0,0,0"
                                            Padding="12,6"
                                            Command="{Binding DataContext.CancelLearnModeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            Content="Cancel" />
                                </Grid>
                            </Border>

                            <CheckBox Margin="0,18,0,0"
                                      IsChecked="{Binding IsAiPartnerMicrophoneTestModeEnabled, Mode=TwoWay}">
                                <TextBlock Text="Microphone test mode (push-to-talk routes microphone to output)"
                                           TextWrapping="Wrap" />
                            </CheckBox>
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       TextWrapping="Wrap"
                                       Text="{Binding AiPartnerMicrophoneStatus}" />

                            <TextBlock Margin="0,18,0,0"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Text="Screenshot capture" />
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Text="AOM captures one fresh IL-2 screenshot when you release push-to-talk, downsizes it to a 1080p envelope, and attaches it to the AI request when available." 
                                       TextWrapping="Wrap" />

                            <Border Margin="0,18,0,0"
                                    Padding="12"
                                    Background="#16263A">
                                <StackPanel>
                                    <TextBlock FontSize="15"
                                               FontWeight="SemiBold"
                                               Text="Live telemetry summary" />
                                    <TextBlock Margin="0,8,0,0"
                                               Foreground="{StaticResource AccentBrush}"
                                               TextWrapping="Wrap"
                                               Text="{Binding AiPartnerTelemetrySummary}" />
                                    <TextBlock Margin="0,8,0,0"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               TextWrapping="Wrap"
                                               Text="{Binding LearnModeStatus}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Padding="18"
                                Background="{StaticResource PanelBrush}">
                            <StackPanel>
                                <TextBlock FontSize="20"
                                           FontWeight="SemiBold"
                                           Text="Mission briefing" />
                                <TextBlock Margin="0,6,0,0"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Text="Paste the sortie briefing or your desired wingman context here."
                                           TextWrapping="Wrap" />
                                <TextBox Margin="0,14,0,0"
                                         MinHeight="180"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         TextWrapping="Wrap"
                                         Text="{Binding AiPartnerBriefing, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                            </StackPanel>
                        </Border>

                        <Grid Grid.Row="1"
                              Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Margin="0,0,12,0"
                                    Padding="14"
                                    Background="#16263A">
                                <StackPanel>
                                    <TextBlock FontSize="16"
                                               FontWeight="SemiBold"
                                               Text="Capture status" />
                                    <TextBlock Margin="0,8,0,0"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               TextWrapping="Wrap"
                                               Text="{Binding AiPartnerLastScreenshotStatus}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1"
                                    Padding="14"
                                    Background="#16263A">
                                <StackPanel>
                                    <TextBlock FontSize="16"
                                               FontWeight="SemiBold"
                                               Text="AI status" />
                                    <TextBlock Margin="0,8,0,0"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               TextWrapping="Wrap"
                                               Text="{Binding AiPartnerConversationStatus}" />
                                    <TextBlock Margin="0,10,0,0"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               Text="AI log file" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               TextWrapping="Wrap"
                                               Text="{Binding AiPartnerLogPath}" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Grid.Row="2"
                                Margin="0,14,0,0"
                                Padding="18"
                                Background="{StaticResource PanelBrush}">
                            <StackPanel>
                                <TextBlock FontSize="20"
                                           FontWeight="SemiBold"
                                           Text="Transcript" />
                                <TextBlock Margin="0,6,0,0"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Text="Hold push-to-talk, speak, and release to send audio to OpenAI. The player and AI exchange will appear here."
                                           TextWrapping="Wrap" />
                                <TextBox Margin="0,14,0,0"
                                         MinHeight="220"
                                         IsReadOnly="True"
                                         VerticalScrollBarVisibility="Auto"
                                         TextWrapping="Wrap"
                                         Text="{Binding AiPartnerTranscript, Mode=OneWay}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="IL-2 Videos Raw">
                <Grid Margin="0,12,0,0"
                      DataContext="{Binding Il2RawVideoLibrary}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Padding="18"
                            Background="{StaticResource PanelBrushMuted}">
                        <StackPanel>
                            <TextBlock FontSize="24"
                                       FontWeight="SemiBold"
                                       Text="IL-2 Videos Raw" />
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Text="Paste a YouTube URL, download the raw mp4, then click any thumbnail card to open the file in your default video player."
                                       TextWrapping="Wrap" />

                            <Grid Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBox Padding="10,8"
                                         VerticalAlignment="Center"
                                         Text="{Binding PendingUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <Button Grid.Column="1"
                                        Margin="12,0,0,0"
                                        Padding="16,8"
                                        Command="{Binding DownloadCommand}"
                                        Content="{Binding DownloadButtonLabel}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1"
                          Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Margin="0,0,12,0"
                                Padding="14"
                                Background="#16263A">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <DockPanel LastChildFill="False">
                                    <Button DockPanel.Dock="Right"
                                            Padding="12,6"
                                            Command="{Binding ChooseLibraryFolderCommand}"
                                            Content="Choose folder" />
                                    <StackPanel>
                                        <TextBlock FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Text="Library" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding LibrarySummary}" />
                                    </StackPanel>
                                </DockPanel>

                                <TextBlock Grid.Row="1"
                                           Margin="0,12,0,0"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Text="Storage path" />
                                <TextBlock Grid.Row="1"
                                           Margin="0,30,0,0"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           TextWrapping="Wrap"
                                           Text="{Binding LibraryPath}" />
                                <TextBlock Grid.Row="2"
                                           Margin="0,10,0,0"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Text="Switching the folder does not move existing videos."
                                           TextWrapping="Wrap" />
                            </Grid>
                        </Border>

                        <Border Grid.Column="1"
                                Padding="14"
                                Background="#16263A">
                            <StackPanel>
                                <TextBlock FontSize="16"
                                           FontWeight="SemiBold"
                                           Text="Status" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           TextWrapping="Wrap"
                                           Text="{Binding Status}" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Grid.Row="2"
                            Margin="0,14,0,0"
                            Padding="18"
                            Background="{StaticResource PanelBrush}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel>
                                <TextBlock FontSize="20"
                                           FontWeight="SemiBold"
                                           Text="Downloaded videos" />
                                <TextBlock Margin="0,6,0,0"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Text="Each card opens the downloaded mp4 in your default player. Thumbnails are cached from YouTube when available."
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <Grid Grid.Row="1"
                                  Margin="0,14,0,0">
                                <TextBlock Foreground="{StaticResource TextMutedBrush}"
                                           Text="No downloaded videos yet."
                                           TextWrapping="Wrap">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasVideos}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ScrollViewer.Style>
                                        <Style TargetType="ScrollViewer">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasVideos}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ScrollViewer.Style>

                                    <ItemsControl ItemsSource="{Binding Videos}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Width="240"
                                                      Margin="0,0,14,14">
                                                    <Button Padding="0"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Command="{Binding OpenCommand}">
                                                        <Border Padding="12"
                                                                Background="{StaticResource PanelBrushMuted}">
                                                            <StackPanel>
                                                                <Border Height="136"
                                                                        Background="#0F1B2B"
                                                                        BorderBrush="#213A54"
                                                                        BorderThickness="1">
                                                                    <Grid>
                                                                        <Image Source="{Binding ThumbnailImage}"
                                                                               Stretch="UniformToFill" />
                                                                        <TextBlock HorizontalAlignment="Center"
                                                                                   VerticalAlignment="Center"
                                                                                   Foreground="{StaticResource TextMutedBrush}"
                                                                                   Text="Thumbnail unavailable">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding ThumbnailImage}" Value="{x:Null}">
                                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>
                                                                    </Grid>
                                                                </Border>

                                                                <TextBlock Margin="0,10,0,0"
                                                                           FontSize="16"
                                                                           FontWeight="SemiBold"
                                                                           Text="{Binding Title}"
                                                                           TextWrapping="Wrap"
                                                                           TextTrimming="CharacterEllipsis" />
                                                                <TextBlock Margin="0,6,0,0"
                                                                           Foreground="{StaticResource TextMutedBrush}"
                                                                           Text="{Binding MetaLine}"
                                                                           TextWrapping="Wrap" />
                                                                <TextBlock Margin="0,8,0,0"
                                                                           Foreground="{StaticResource AccentBrush}"
                                                                           Text="Open in default player" />
                                                            </StackPanel>
                                                        </Border>
                                                    </Button>

                                                    <Button HorizontalAlignment="Right"
                                                            VerticalAlignment="Top"
                                                            Margin="0,10,10,0"
                                                            Padding="10,4"
                                                            Command="{Binding EditCommand}"
                                                            Content="Edit"
                                                            ToolTip="Open the editor window for this video" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <TextBlock Grid.Row="2"
                   Margin="2,18,0,0"
                   Foreground="{StaticResource TextMutedBrush}"
                   Text="{Binding Footer}" />
    </Grid>
</Window>
